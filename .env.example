# KBOS — environment configuration
# Copy to .env and edit before starting:
#   cp .env.example .env
#   sed -i "s/DOCKER_UID=.*/DOCKER_UID=$(id -u)/; s/DOCKER_GID=.*/DOCKER_GID=$(id -g)/" .env

# ── Host user/group ───────────────────────────────────────────────────────────
# Run `id -u` and `id -g` on the host to get these values.
# Files inside the vault will be owned by this UID:GID.
DOCKER_UID=1000
DOCKER_GID=1000

# ── Vault paths ───────────────────────────────────────────────────────────────
# Absolute or relative path to your primary vault directory on the host.
VAULT_PATH=./vault

# Directory that houses additional vaults (multi-vault feature).
VAULTS_BASE=./vaults

# ── Web UI port ───────────────────────────────────────────────────────────────
# Host port the KBOS web UI is exposed on.
KBOS_PORT=3000
